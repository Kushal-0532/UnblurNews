# UnBlur Backend Configuration
# Copy this file to .env and fill in your values

# NewsAPI key (free at https://newsapi.org)
NEWSAPI_KEY=your_newsapi_key_here

# OpenAI key (optional — enables GPT-3.5 summaries)
OPENAI_API_KEY=your_openai_key_here

# Path to fine-tuned model files
MODEL_PATH=./backend/models

# SQLite cache database path
CACHE_DB=./cache/unblur.db

# Backend server settings
PORT=8000

# Extension frontend URL (for CORS)
BACKEND_URL=http://localhost:8000
