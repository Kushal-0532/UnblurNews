# UnBlur Backend Configuration
# Copy this file to .env and fill in your values

# NewsAPI key (free at https://newsapi.org)
NEWSAPI_KEY=your_newsapi_key_here

# OpenAI key (optional — enables GPT-3.5 summaries)
OPENAI_API_KEY=your_openai_key_here

# Path to fine-tuned model files (used when MODEL_REPO_ID is unset)
MODEL_PATH=./backend/models

# Hugging Face Hub private model repo (overrides MODEL_PATH when set)
# MODEL_REPO_ID=your-username/unblur-model
# HF_TOKEN=hf_your_token_here

# SQLite cache database path
CACHE_DB=./cache/unblur.db

# Redis connection URL (Upstash-compatible, rediss:// for TLS). If unset,
# falls back to the SQLite cache above.
# REDIS_URL=rediss://default:password@your-upstash-host:6379

# Backend server settings
PORT=8000

# Extension frontend URL (for CORS)
BACKEND_URL=http://localhost:8000
